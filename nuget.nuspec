<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2010/07/nuspec.xsd">
    <metadata>
        <version>2.0.0</version>
        <id>datatables.net-rowreorder-se</id>
        <description>This is RowReorder for DataTables with styling for [SemanticUI](https://semantic-ui.com/)</description>
        <repository type="git" url="https://github.com/DataTables/RowReorder"/>
        <authors>SpryMedia Ltd</authors>
        <projectUrl>http://datatables.net</projectUrl>
        <license type="expression">MIT</license>
        <tags>RowReorder  Row Reordering  Semantic  SemanticUI  Semantic UI  Datatables table</tags>
        <dependencies>
            <dependency id="datatables.net-rowreorder" version="2.0.0"/>
            <dependency id="datatables.net-se" version="[3.0.0, 4.0.0)"/>
        </dependencies>
        <contentFiles>
            <files include="**/*" buildAction="Content"/>
        </contentFiles>
        <readme>Readme.md</readme>
    </metadata>
    <files>
        <file src="Readme.md" target=""/>
        <file src="js/rowReorder.semanticui.js" target="content\Scripts"/>
        <file src="js/rowReorder.semanticui.js" target="contentFiles\any\any\wwwroot\js"/>
        <file src="js/rowReorder.semanticui.min.js" target="content\Scripts"/>
        <file src="js/rowReorder.semanticui.min.js" target="contentFiles\any\any\wwwroot\js"/>
        <file src="js/rowReorder.semanticui.min.mjs" target="content\Scripts"/>
        <file src="js/rowReorder.semanticui.min.mjs" target="contentFiles\any\any\wwwroot\js"/>
        <file src="js/rowReorder.semanticui.mjs" target="content\Scripts"/>
        <file src="js/rowReorder.semanticui.mjs" target="contentFiles\any\any\wwwroot\js"/>
        <file src="css/rowReorder.semanticui.css" target="content\Content"/>
        <file src="css/rowReorder.semanticui.css" target="contentFiles\any\any\wwwroot\css"/>
        <file src="css/rowReorder.semanticui.min.css" target="content\Content"/>
        <file src="css/rowReorder.semanticui.min.css" target="contentFiles\any\any\wwwroot\css"/>
    </files>
</package>
